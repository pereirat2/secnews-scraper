# Copy to .env and fill in your values. chmod 600 .env after editing.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Numeric chat/group ID (negative for groups). To find it:
#   1. Add the bot to the group.
#   2. Send any message in the group.
#   3. curl https://api.telegram.org/bot<TOKEN>/getUpdates | jq '.result[].message.chat'
TELEGRAM_CHAT_ID=

# Optional overrides (defaults are sensible for /opt/secnews on Linux)
# SECNEWS_DATA_DIR=/var/lib/secnews
# SECNEWS_LOG_DIR=/var/log/secnews
# SECNEWS_LOG_LEVEL=INFO
